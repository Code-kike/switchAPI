{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "switchAPI",
  "version": "0.1.0",
  "identifier": "com.codekike.switchapi",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "switchAPI",
        "width": 1100,
        "height": 760,
        "minWidth": 480,
        "minHeight": 360
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "dmg", "nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"],
    "externalBin": ["binaries/switchapi-agent"],
    "createUpdaterArtifacts": false
  },
  "plugins": {}
}
